# =============================================================================
# Polymarket Arbitrage Bot - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Market Selection
# -----------------------------------------------------------------------------
# Coin to monitor for arbitrage opportunities (e.g. BTC, ETH, SOL, MATIC)
MARKET_ASSET=BTC

# -----------------------------------------------------------------------------
# Polymarket CLOB API
# -----------------------------------------------------------------------------
# HTTP endpoint for the Polymarket CLOB API
CLOB_HTTP_URL=https://clob.polymarket.com

# WebSocket endpoint for live orderbook updates
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# -----------------------------------------------------------------------------
# Wallet / Blockchain
# -----------------------------------------------------------------------------
# Your wallet private key (required for live trading, omit for detection-only mode)
PRIVATE_KEY=0xyour_private_key_here

# Proxy wallet address (Gnosis Safe or EOA used by Polymarket for trading)
PROXY_WALLET=0xyour_proxy_wallet_address

# Signature type: EOA (default) or GNOSIS_SAFE
SIGNATURE_TYPE=EOA

# Polygon RPC endpoint
RPC_URL=https://polygon-rpc.com

# -----------------------------------------------------------------------------
# Arbitrage Strategy
# -----------------------------------------------------------------------------
# Sum threshold for ASK prices to trigger arbitrage detection (default: 1.0)
# When UP_ASK + DOWN_ASK < ARBITRAGE_THRESHOLD, an opportunity is flagged.
# Note: a ~2% taker fee is deducted automatically. Only opportunities profitable
# after fees (net spread >= 0.5%) will be executed.
ARBITRAGE_THRESHOLD=1.0

# Fixed token quantity to buy per side (minimum: 5.0)
TOKEN_AMOUNT=5.0

# Taker fee rate for profitability calculation (default: 0.02 = 2%)
TAKER_FEE_RATE=0.02

# Maximum individual spread (ask - bid) per side before skipping (default: 0.10)
# Wide spreads indicate illiquid/risky conditions.
MAX_SPREAD=0.10

# Velocity lockout: skip trading if ask_sum moves more than this in 3 seconds
# (default: 0.15 = 15 cents combined movement)
VELOCITY_THRESHOLD=0.15

# How long to pause trading after a velocity lockout event (default: 5 seconds)
VELOCITY_LOCKOUT_SECS=5

# Maximum slippage allowed when unwinding a partial fill (default: 0.10 = 10%).
# If only one leg fills, the bot sells that leg at buy_price * (1 - MAX_UNWIND_SLIPPAGE).
MAX_UNWIND_SLIPPAGE=0.10

# -----------------------------------------------------------------------------
# Display & Data
# -----------------------------------------------------------------------------
# Enable TUI display (terminal clear + redraw). Set false in Docker.
DISPLAY_UI=false

# Directory for log files (monitor.log, error.log).
# In Docker, set to /app/data to persist via the mounted volume.
DATA_DIR=./data

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
RUST_LOG=info

# -----------------------------------------------------------------------------
# Telegram Notifications (optional)
# -----------------------------------------------------------------------------
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Chat ID (use @userinfobot or getUpdates API to find yours)
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# SOCKS5 Proxy (optional)
# -----------------------------------------------------------------------------
# Routes CLOB order calls through a SOCKS5 proxy to bypass regional restrictions.
# Only affects order placement — WebSocket, Gamma API, and RPC calls are direct.
# Use socks5h:// (not socks5://) so DNS is resolved on the proxy side.
# SOCKS5_PROXY_URL=socks5h://user:pass@host:port
